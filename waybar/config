{
    "layer": "top",
    "position": "top",
    "spacing": 10,
    "height": 0,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,

    "modules-left": ["sway/workspaces"],
    "modules-center": ["sway/window"],
    "modules-right": ["tray", "custom/separator", "sway/language", "custom/separator", "network", "custom/separator", "battery", "custom/separator", "clock"],

    "custom/separator": {
        "format": "|"
    },

    "sway/workspaces": {
	    "tooltip": false
    },

    "sway/window": {
        "tooltip": false
    },

    "network": {
        "format-wifi": "wi-fi, {signalStrength}%",
	    "format-ethernet": "ethernet",
	    "format-disconnected": "no connection",
	    "tooltip": false
    },

    "battery": {
        "format": "{capacity}%",
	    "format-charging": "{capacity}%, charging",
	    "tooltip": false
    },

    "clock": {
        "format": "{:%d.%m.%Y, %a, %H:%M}",
	    "tooltip": false
    },

    "sway/language": {
        "format": "{short}"
    }
}

{
    "layer": "top",
    "position": "top",
    "spacing": 5,
    "height": 0,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,

    "modules-left": ["sway/workspaces"],
    "modules-center": ["sway/window"],
    "modules-right": ["tray", "custom/separator", "sway/language", "custom/separator", "network", "custom/separator", "clock"],

    "tray": {
        "spacing": 8
    },

    "custom/separator": {
        "format": "|",
        "tooltip": false
    },

    "sway/workspaces": {
	    "tooltip": false
    },

    "sway/window": {
        "format": {},
        "max-length": 100,
        "tooltip": false
    },

    "network": {
        "format-wifi": "wi-fi",
	    "format-ethernet": "ethernet",
	    "format-disconnected": "no connection",
	    "tooltip": false
    },

    "clock": {
        "format": "{:%d.%m.%Y, %a, %H:%M}",
	    "tooltip": false
    },

    "sway/language": {
        "format": "{short}",
        "tooltip": false
    }
}

// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "use_system_path_prompts": false,
  "use_system_prompts": false,
  "edit_predictions": {
    "mode": "subtle",
    "allow_data_collection": "no",
  },
  "show_edit_predictions": false,
  "diagnostics_max_severity": "off",
  "go_to_definition_fallback": "none",
  "linked_edits": false,
  "enable_language_server": false,
  "word_diff_enabled": false,
  "lsp_document_colors": "none",
  "debugger": {
    "format_dap_log_messages": false,
    "log_dap_communications": false,
    "save_breakpoints": false,
    "button": false,
  },
  "proxy": "",
  "disable_ai": true,
  "git": {
    "disable_git": true,
    "enable_status": false,
    "enable_diff": false,
    "show_stage_restore_buttons": false,
    "branch_picker": {
      "show_author_name": false,
    },
    "blame": {
      "show_avatar": false,
    },
    "inline_blame": {
      "enabled": false,
      "padding": 6,
    },
  },
  "agent": {
    "show_merge_conflict_indicator": false,
    "expand_edit_card": false,
    "expand_terminal_card": false,
    "notify_when_agent_waiting": "never",
    "enable_feedback": false,
    "max_content_width": 640.0,
    "default_width": 320.0,
    "button": false,
    "favorite_models": [],
    "model_parameters": [],
  },
  "collaboration_panel": {
    "default_width": 320.0,
    "button": false,
  },
  "git_panel": {
    "diff_stats": false,
    "dock": "right",
    "button": true,
    "folder_icons": false,
    "tree_view": true,
    "status_style": "label_color",
    "default_width": 320.0,
  },
  "outline_panel": {
    "auto_reveal_entries": false,
    "git_status": false,
    "button": false,
    "auto_fold_dirs": false,
    "folder_icons": false,
    "file_icons": false,
    "default_width": 320.0,
  },
  "terminal": {
    "working_directory": "current_project_directory",
    "dock": "bottom",
    "minimum_contrast": 50.0,
    "alternate_scroll": "off",
    "cursor_shape": "block",
    "show_count_badge": false,
  },
  "zoomed_padding": false,
  "window_decorations": "server",
  "focus_follows_mouse": {
    "debounce_ms": 200,
  },
  "preview_tabs": {
    "enable_preview_file_from_code_navigation": false,
    "enable_preview_from_multibuffer": false,
    "enable_preview_from_project_panel": false,
    "enabled": false,
  },
  "tabs": {
    "show_close_button": "hover",
  },
  "tab_bar": {
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": false,
    "show": true,
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_branch_name": false,
    "show_project_items": false,
    "button_layout": "",
    "show_menus": false,
    "show_user_menu": false,
  },
  "status_bar": {
    "active_encoding_button": "disabled",
    "cursor_position_button": false,
    "active_language_button": false,
  },
  "project_panel": {
    "sticky_scroll": false,
    "show_diagnostics": "off",
    "auto_reveal_entries": false,
    "git_status": false,
    "default_width": 320.0,
    "auto_open": {
      "on_drop": false,
      "on_paste": false,
      "on_create": false,
    },
    "drag_and_drop": false,
    "bold_folder_labels": true,
    "auto_fold_dirs": false,
    "folder_icons": false,
    "file_icons": false,
    "button": true,
  },
  "scan_symlinks": "always",
  "close_on_file_delete": true,
  "restore_on_file_reopen": false,
  "file_finder": {
    "file_icons": false,
    "include_ignored": "all",
  },
  "search": {
    "button": false,
    "center_on_match": true,
    "include_ignored": true,
    "regex": true,
  },
  "lsp_highlight_debounce": 50,
  "diagnostics": {
    "lsp_pull_diagnostics": {
      "enabled": false,
    },
    "include_warnings": false,
    "button": false,
    "inline": {
      "update_debounce_ms": 50,
    },
  },
  "show_completions_on_input": false,
  "modeline_lines": 4,
  "colorize_brackets": true,
  "extend_comment_on_newline": false,
  "middle_click_paste": true,
  "tasks": {
    "prefer_lsp": false,
    "enabled": false,
  },
  "inlay_hints": {
    "edit_debounce_ms": 600,
    "show_other_hints": false,
    "show_parameter_hints": false,
    "show_type_hints": false,
    "show_value_hints": false,
  },
  "completions": {
    "lsp_insert_mode": "insert",
    "lsp": false,
    "words": "disabled",
    "words_min_length": 2,
  },
  "show_completion_documentation": false,
  "show_whitespaces": "none",
  "allow_rewrap": "anywhere",
  "vim": {
    "cursor_shape": {
      "visual": "bar",
      "replace": "bar",
      "insert": "bar",
      "normal": "bar",
    },
  },
  "toolbar": {
    "breadcrumbs": false,
    "selections_menu": false,
    "agent_review": false,
    "quick_actions": false,
  },
  "minimap": {
    "thumb": "hover",
    "display_in": "all_editors",
    "show": "never",
  },
  "scrollbar": {
    "axes": {
      "vertical": false,
      "horizontal": false,
    },
    "diagnostics": "none",
    "selected_symbol": false,
    "selected_text": false,
    "search_results": false,
    "git_diff": false,
    "cursors": false,
    "show": "never",
  },
  "inline_code_actions": false,
  "gutter": {
    "folds": false,
    "bookmarks": false,
    "breakpoints": false,
    "runnables": false,
  },
  "drag_and_drop_selection": {
    "delay": 200,
    "enabled": false,
  },
  "hover_popover_hiding_delay": 200,
  "hover_popover_sticky": false,
  "hover_popover_delay": 200,
  "hover_popover_enabled": false,
  "horizontal_scroll_margin": 4.0,
  "vertical_scroll_margin": 2.0,
  "expand_excerpt_lines": 4,
  "minimum_contrast_for_highlights": 50.0,
  "rounded_selection": false,
  "unnecessary_code_fade": 0.5,
  "text_rendering_mode": "platform_default",
  "ui_font_family": "FreeMono",
  "buffer_font_family": "FreeMono",
  "auto_update": false,
  "restore_on_startup": "none",
  "cli_default_open_behavior": "new_window",
  "on_last_window_closed": "quit_app",
  "when_closing_with_no_tabs": "keep_window_open",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
    "anthropic_retention": false,
  },
  "session": {
    "restore_unsaved_buffers": false,
    "trust_all_worktrees": true,
  },
  "icon_theme": "Zed (Default)",
  "ui_font_size": 18.0,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "system",
    "light": "Gruvbox Light",
    "dark": "Gruvbox Dark",
  },
}
